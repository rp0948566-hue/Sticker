@property --gsc-cpl-loop-scale { syntax: '<number>'; initial-value: 1; inherits: false; }
@property --gsc-cpl-loop-rotate { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
@property --gsc-cpl-loop-translate-y { syntax: '<length-percentage>'; initial-value: 0; inherits: false; }

.gsc-countdown-product-label-inner {
  display: block;
  width: fit-content;
  transform:
    translateY(var(--gsc-cpl-loop-translate-y))
    rotate(var(--gsc-cpl-loop-rotate))
    scale(var(--gsc-cpl-loop-scale));
}

@keyframes gsc-cpl-loop-beat {
  0% { --gsc-cpl-loop-scale: 1; }
  11% { --gsc-cpl-loop-scale: 1.05; }
  23% { --gsc-cpl-loop-scale: 1; }
  100% { --gsc-cpl-loop-scale: 1; }
}
.gsc-cpl-loop-beat { animation: gsc-cpl-loop-beat 4s ease-in-out infinite; }

@keyframes gsc-cpl-loop-shake {
  0% { --gsc-cpl-loop-rotate: 0deg; }
  4% { --gsc-cpl-loop-rotate: -6deg; }
  8% { --gsc-cpl-loop-rotate: 6deg; }
  11% { --gsc-cpl-loop-rotate: -5deg; }
  15% { --gsc-cpl-loop-rotate: 5deg; }
  19% { --gsc-cpl-loop-rotate: -3deg; }
  22% { --gsc-cpl-loop-rotate: 3deg; }
  25% { --gsc-cpl-loop-rotate: 0deg; }
  100% { --gsc-cpl-loop-rotate: 0deg; }
}
.gsc-cpl-loop-shake { animation: gsc-cpl-loop-shake 4s ease-in-out infinite; }

@keyframes gsc-cpl-loop-bounce {
  0% { --gsc-cpl-loop-translate-y: 0; }
  8% { --gsc-cpl-loop-translate-y: -0.5em; }
  15% { --gsc-cpl-loop-translate-y: 0; }
  20% { --gsc-cpl-loop-translate-y: -0.25em; }
  25% { --gsc-cpl-loop-translate-y: 0; }
  100% { --gsc-cpl-loop-translate-y: 0; }
}
.gsc-cpl-loop-bounce { animation: gsc-cpl-loop-bounce 4s cubic-bezier(0.28, 0.84, 0.42, 1) infinite; }

@keyframes gsc-cpl-loop-swing {
  0% { --gsc-cpl-loop-rotate: 0deg; }
  9% { --gsc-cpl-loop-rotate: 7deg; }
  18% { --gsc-cpl-loop-rotate: -6deg; }
  27% { --gsc-cpl-loop-rotate: 4deg; }
  36% { --gsc-cpl-loop-rotate: -2deg; }
  46% { --gsc-cpl-loop-rotate: 0deg; }
  100% { --gsc-cpl-loop-rotate: 0deg; }
}
.gsc-cpl-loop-swing { animation: gsc-cpl-loop-swing 4.6s ease-in-out infinite; }
