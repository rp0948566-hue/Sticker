{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/whatsapp catalogue/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/home.html" },
    { "source": "/frontend/ACCESSORIES", "destination": "/frontend/ACCESSORIES/index.html" },
    { "source": "/frontend/CARD SKINS", "destination": "/frontend/CARD SKINS/index.html" },
    { "source": "/frontend/CUSTOM STICKERS", "destination": "/frontend/CUSTOM STICKERS/index.html" },
    { "source": "/frontend/MYSTERY BOX", "destination": "/frontend/MYSTERY BOX/index.html" },
    { "source": "/frontend/MACBOOK SKINS", "destination": "/frontend/MACBOOK SKINS/index.html" },
    { "source": "/frontend/FRAME/FRAME", "destination": "/frontend/FRAME/FRAME/index.html" },
    { "source": "/frontend/EXPERIENCE MAGIC/CUTE", "destination": "/frontend/EXPERIENCE MAGIC/CUTE/index.html" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
