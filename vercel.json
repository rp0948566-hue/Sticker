{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/whatsapp catalogue/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/home.html" },
    { "source": "/checkout", "destination": "/order-system/frontend/checkout/index.html" },
    { "source": "/login", "destination": "/frontend/Login Page/index.html" },
    { "source": "/frontend/A3 SIZE", "destination": "/frontend/A3 SIZE/index.html" },
    { "source": "/frontend/ACCESSORIES", "destination": "/frontend/ACCESSORIES/index.html" },
    { "source": "/frontend/AESTHETIC", "destination": "/frontend/AESTHETIC/index.html" },
    { "source": "/frontend/ANIME", "destination": "/frontend/ANIME/index.html" },
    { "source": "/frontend/ANIME MINI", "destination": "/frontend/ANIME MINI/index.html" },
    { "source": "/frontend/ARTIST PRINTS", "destination": "/frontend/ARTIST PRINTS/index.html" },
    { "source": "/frontend/CARD", "destination": "/frontend/CARD/index.html" },
    { "source": "/frontend/CARS", "destination": "/frontend/CARS/index.html" },
    { "source": "/frontend/CUSTOM STICKERS", "destination": "/frontend/CUSTOM STICKERS/index.html" },
    { "source": "/frontend/DEVOTIONAL", "destination": "/frontend/DEVOTIONAL/index.html" },
    { "source": "/frontend/FRAME/FRAME", "destination": "/frontend/FRAME/FRAME/index.html" },
    { "source": "/frontend/MARVELS", "destination": "/frontend/MARVELS/index.html" },
    { "source": "/frontend/MOVIES", "destination": "/frontend/MOVIES/index.html" },
    { "source": "/frontend/NEW ANIME", "destination": "/frontend/NEW ANIME/index.html" },
    { "source": "/frontend/PINK LAVENDER", "destination": "/frontend/PINK LAVENDER/index.html" },
    { "source": "/frontend/QUOTES", "destination": "/frontend/QUOTES/index.html" },
    { "source": "/frontend/SHINCHAN", "destination": "/frontend/SHINCHAN/index.html" },
    { "source": "/frontend/SONG COVER 8X8", "destination": "/frontend/SONG COVER 8X8/index.html" },
    { "source": "/frontend/SONGS", "destination": "/frontend/SONGS/index.html" },
    { "source": "/frontend/SPLIT ART", "destination": "/frontend/SPLIT ART/index.html" },
    { "source": "/frontend/SPLIT POSTERS", "destination": "/frontend/SPLIT POSTERS/index.html" },
    { "source": "/frontend/SPORTS", "destination": "/frontend/SPORTS/index.html" },
    { "source": "/frontend/VAN GOGH", "destination": "/frontend/VAN GOGH/index.html" },
    { "source": "/frontend/VISION BOARD", "destination": "/frontend/VISION BOARD/index.html" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
