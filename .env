# ─────────────────────────────────────────────────────────────────────────────
# StickItUp — Local Development Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit this file to git.
#            .env is already listed in .gitignore.
#
# For Vercel production deployment, set these in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Replace <db_password> with the password for the STICKER Atlas database user.
# Find it in: MongoDB Atlas → Database Access → Edit user → Password
MONGODB_URI=mongodb+srv://STICKER:<db_password>@stickitup.ll3zitw.mongodb.net/stickitup?retryWrites=true&w=majority&appName=stickitup

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret. Example:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=supersecretjwtsecretkeychangeinproduction

# ── Optional: Upstash Redis (Security Shield cross-instance threat sync) ──────
# Leave blank to fall back to in-memory threat tracking (safe for single instance)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Optional: Admin alert email (Security Shield notifications) ───────────────
# ADMIN_ALERT_EMAIL=admin@yourdomain.com

# ── Optional: Cloudinary (product image uploads) ─────────────────────────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── Optional: Payment webhook ─────────────────────────────────────────────────
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── Optional: CORS (production frontend URL) ─────────────────────────────────
# ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://yourdomain.com
